        </div>

        <!-- Footer -->
        <footer class="dashboard-footer">
            <p>Urgent Home Repairs Acquisition Dashboard | Data last updated: October 31, 2023 11:59 PM</p>
            <div class="footer-links">
                <a href="#"><i class="fas fa-download"></i> Export Report</a>
                <a href="#"><i class="fas fa-question-circle"></i> Help & Documentation</a>
                <a href="#"><i class="fas fa-cog"></i> Settings</a>
            </div>
        </footer>
    </div>

    <script>
        // Initialize Charts
        document.addEventListener('DOMContentLoaded', function() {
            // Time Series Chart
            const timeSeriesCtx = document.getElementById('timeSeriesChart').getContext('2d');
            const timeSeriesChart = new Chart(timeSeriesCtx, {
                type: 'line',
                data: {
                    labels: ['Oct 1', 'Oct 5', 'Oct 10', 'Oct 15', 'Oct 20', 'Oct 25', 'Oct 30'],
                    datasets: [
                        {
                            label: 'Sign-ups',
                            data: [35, 42, 38, 55, 47, 60, 52],
                            borderColor: '#2a5ca9',
                            backgroundColor: 'rgba(42, 92, 169, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4
                        },
                        {
                            label: 'Ad Spend ($)',
                            data: [1200, 1500, 1400, 1800, 1700, 2200, 2000],
                            borderColor: '#ff6b35',
                            backgroundColor: 'rgba(255, 107, 53, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Sign-ups'
                            }
                        },
                        y1: {
                            position: 'right',
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Ad Spend ($)'
                            },
                            grid: {
                                drawOnChartArea: false
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false
                        }
                    }
                }
            });
            
            // Service Type Chart
            const serviceTypeCtx = document.getElementById('serviceTypeChart').getContext('2d');
            const serviceTypeChart = new Chart(serviceTypeCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Plumbing', 'Electrical', 'HVAC', 'Emergency Repair', 'Other'],
                    datasets: [{
                        data: [45, 25, 15, 10, 5],
                        backgroundColor: [
                            '#1565c0',
                            '#ef6c00',
                            '#2e7d32',
                            '#c62828',
                            '#6c757d'
                        ],
                        borderWidth: 2,
                        borderColor: 'white'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return `${context.label}: ${context.raw}% of sign-ups`;
                                }
                            }
                        }
                    }
                }
            });
            
            // Correlation Chart
            const correlationCtx = document.getElementById('correlationChart').getContext('2d');
            const correlationChart = new Chart(correlationCtx, {
                type: 'scatter',
                data: {
                    datasets: [
                        {
                            label: 'Plumbing',
                            data: [
                                {x: 800, y: 25},
                                {x: 1200, y: 38},
                                {x: 1500, y: 42},
                                {x: 1800, y: 55},
                                {x: 2200, y: 60}
                            ],
                            backgroundColor: '#1565c0',
                            pointRadius: 8
                        },
                        {
                            label: 'Electrical',
                            data: [
                                {x: 1000, y: 20},
                                {x: 1400, y: 28},
                                {x: 1700, y: 35},
                                {x: 2000, y: 40},
                                {x: 2400, y: 45}
                            ],
                            backgroundColor: '#ef6c00',
                            pointRadius: 8
                        },
                        {
                            label: 'HVAC',
                            data: [
                                {x: 1200, y: 15},
                                {x: 1600, y: 22},
                                {x: 1900, y: 28},
                                {x: 2300, y: 32},
                                {x: 2600, y: 38}
                            ],
                            backgroundColor: '#2e7d32',
                            pointRadius: 8
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: 'Ad Spend ($)'
                            },
                            beginAtZero: true
                        },
                        y: {
                            title: {
                                display: true,
                                text: 'Sign-ups'
                            },
                            beginAtZero: true
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return `${context.dataset.label}: $${context.parsed.x} spend → ${context.parsed.y} sign-ups`;
                                }
                            }
                        }
                    }
                }
            });
            
            // Tab switching for heatmap
            const tabs = document.querySelectorAll('.chart-tab');
            tabs.forEach(tab => {
                tab.addEventListener('click', function() {
                    // Remove active class from all tabs
                    tabs.forEach(t => t.classList.remove('active'));
                    
                    // Add active class to clicked tab
                    this.classList.add('active');
                    
                    // Show the corresponding heatmap
                    const tabType = this.getAttribute('data-tab');
                    document.getElementById('day-heatmap').style.display = tabType === 'day' ? 'flex' : 'none';
                    document.getElementById('time-heatmap').style.display = tabType === 'time' ? 'flex' : 'none';
                });
            });
            
            // Filter application
            const applyFiltersBtn = document.querySelector('.apply-filters');
            applyFiltersBtn.addEventListener('click', function() {
                // Show loading state
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Applying Filters...';
                
                // Simulate API call
                setTimeout(() => {
                    this.innerHTML = '<i class="fas fa-check-circle"></i> Filters Applied';
                    
                    // Reset button text after 2 seconds
                    setTimeout(() => {
                        this.innerHTML = '<i class="fas fa-check-circle"></i> Apply Filters';
                    }, 2000);
                    
                    // In a real application, this would update the charts with filtered data
                    console.log('Filters applied - would update charts with filtered data');
                }, 1000);
            });
            
            // Refresh data button
            const refreshBtn = document.getElementById('refresh-data');
            refreshBtn.addEventListener('click', function() {
                // Show loading state
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';
                this.disabled = true;
                
                // Simulate API call
                setTimeout(() => {
                    this.innerHTML = originalText;
                    this.disabled = false;
                    
                    // Show success message
                    alert('Data refreshed successfully!');
                }, 1500);
            });
            
            // Set default dates to current month
            const now = new Date();
            const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);
            const lastDay = new Date(now.getFullYear(), now.getMonth() + 1, 0);
            
            document.getElementById('start-date').valueAsDate = firstDay;
            document.getElementById('end-date').valueAsDate = lastDay;
        });
    </script>
</body>
</html>
