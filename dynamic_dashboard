        // Initialize Event Listeners
        function initializeEventListeners() {
            // Refresh Data Button
            document.getElementById('refresh-data').addEventListener('click', refreshData);

            // Apply Filters Button
            document.getElementById('apply-filters').addEventListener('click', applyFilters);

            // Reset Filters Button
            document.getElementById('reset-filters').addEventListener('click', resetFilters);

            // Download Menu
            document.getElementById('download-btn').addEventListener('click', toggleDownloadMenu);

            // Download Options
            document.querySelectorAll('.download-option').forEach(option => {
                option.addEventListener('click', handleDownload);
            });

            // Close download menu when clicking elsewhere
            document.addEventListener('click', closeDownloadMenu);

            // Notification Bell
            document.getElementById('notification-bell').addEventListener('click', showNotifications);

            // Quick Action Buttons
            document.getElementById('add-campaign').addEventListener('click', () => showModal('Add New Campaign', 'Create a new marketing campaign. This feature allows you to set up targeted campaigns for different services and channels.'));
            document.getElementById('optimize-budget').addEventListener('click', () => showModal('Optimize Budget', 'AI-powered budget optimization suggestions based on historical performance data.'));
            document.getElementById('view-alerts').addEventListener('click', () => showModal('View Alerts', '3 active alerts:<br>1. CPA increased by 10%<br>2. Facebook ROI below target<br>3. New high-performing keyword detected'));
            document.getElementById('compare-periods').addEventListener('click', () => showModal('Compare Periods', 'Compare current month vs previous month performance metrics.'));
            document.getElementById('generate-report').addEventListener('click', () => showModal('Generate Report', 'Generate a comprehensive performance report for selected time period.'));

            // Chart Action Buttons
            document.getElementById('drilldown-service').addEventListener('click', () => showModal('Service Drill Down', 'Detailed breakdown of service performance by region and channel.'));
            document.getElementById('funnel-details').addEventListener('click', () => showModal('Funnel Details', 'Conversion rates at each stage of the acquisition funnel with optimization recommendations.'));

            // Data Info Button
            document.getElementById('data-info').addEventListener('click', () => showModal('Data Quality Information', 'Data Sources: Google Analytics, Facebook Ads, CRM System<br>Update Frequency: Real-time<br>Data Completeness: 98%'));

            // Footer Links
            document.getElementById('export-report-link').addEventListener('click', (e) => { e.preventDefault(); toggleDownloadMenu(); });
            document.getElementById('help-docs-link').addEventListener('click', (e) => { e.preventDefault(); showModal('Help & Documentation', 'User guide and documentation for the dashboard features.'); });
            document.getElementById('dashboard-settings-link').addEventListener('click', (e) => { e.preventDefault(); showModal('Dashboard Settings', 'Customize dashboard preferences and notification settings.'); });
            document.getElementById('feedback-link').addEventListener('click', (e) => { e.preventDefault(); showModal('Submit Feedback', 'We value your feedback to improve the dashboard.'); });

            // Tab switching for heatmap
            document.querySelectorAll('.chart-tab').forEach(tab => {
                tab.addEventListener('click', switchHeatmapTab);
            });

            // Modal Buttons
            document.getElementById('close-modal').addEventListener('click', closeModal);
            document.getElementById('modal-close-btn').addEventListener('click', closeModal);
            document.getElementById('modal-action-btn').addEventListener('click', modalAction);

            // Slider updates
            document.getElementById('ad-spend-range').addEventListener('input', updateAdSpendValue);
            document.getElementById('conversion-range').addEventListener('input', updateConversionValue);

            // Checkbox updates for filter counts
            document.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                checkbox.addEventListener('change', updateFilterCounts);
            });

            // Initialize filter counts
            updateFilterCounts();
        }

        // Initialize Date Pickers
        function initializeDatePickers() {
            const now = new Date();
            const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);
            const lastDay = new Date(now.getFullYear(), now.getMonth() + 1, 0);

            document.getElementById('start-date').valueAsDate = firstDay;
            document.getElementById('end-date').valueAsDate = lastDay;

            // Set max date to today
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('start-date').max = today;
            document.getElementById('end-date').max = today;

            // Date change listeners
            document.getElementById('start-date').addEventListener('change', function() {
                const startDate = this.value;
                document.getElementById('end-date').min = startDate;

                if (new Date(document.getElementById('end-date').value) < new Date(startDate)) {
                    document.getElementById('end-date').value = startDate;
                }
            });
        }

        // Initialize File Upload
        function initializeFileUpload() {
            const uploadArea = document.getElementById('upload-area');
            const fileInput = document.getElementById('file-input');
            const browseBtn = document.getElementById('browse-btn');
            const fileList = document.getElementById('file-list');

            // Browse button click
            browseBtn.addEventListener('click', () => fileInput.click());

            // File input change
            fileInput.addEventListener('change', handleFileSelect);

            // Drag and drop
            uploadArea.addEventListener('dragover', (e) => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--primary)';
                uploadArea.style.backgroundColor = 'rgba(42, 92, 169, 0.1)';
            });

            uploadArea.addEventListener('dragleave', () => {
                uploadArea.style.borderColor = 'var(--primary-light)';
                uploadArea.style.backgroundColor = 'rgba(42, 92, 169, 0.05)';
            });

            uploadArea.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadArea.style.borderColor = 'var(--primary-light)';
                uploadArea.style.backgroundColor = 'rgba(42, 92, 169, 0.05)';

                if (e.dataTransfer.files.length) {
                    handleFiles(e.dataTransfer.files);
                }
            });

            function handleFileSelect(e) {
                if (e.target.files.length) {
                    handleFiles(e.target.files);
                }
            }

            function handleFiles(files) {
                for (let file of files) {
                    addFileToList(file);
                }
                showNotification(`Successfully uploaded ${files.length} file(s)`, 'success');
            }

            function addFileToList(file) {
                const fileId = Date.now() + Math.random();
                uploadedFiles.push({
                    id: fileId,
                    file: file
                });

                const fileItem = document.createElement('div');
                fileItem.className = 'file-item';
                fileItem.dataset.id = fileId;

                const fileSize = formatFileSize(file.size);

                fileItem.innerHTML = `
                    <div class="file-info">
                        <i class="fas fa-file" style="color: var(--primary);"></i>
                        <div>
                            <div class="file-name">${file.name}</div>
                            <div class="file-size">${fileSize}</div>
                        </div>
                    </div>
                    <div class="file-actions">
                        <button class="file-action-btn view-file" title="View">
                            <i class="fas fa-eye"></i>
                        </button>
                        <button class="file-action-btn delete-file" title="Delete">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `;

                fileList.appendChild(fileItem);

                // Add event listeners to the new buttons
                fileItem.querySelector('.view-file').addEventListener('click', () => viewFile(fileId));
                fileItem.querySelector('.delete-file').addEventListener('click', () => deleteFile(fileId));
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }
        }

        // File Functions
        function viewFile(fileId) {
            const fileObj = uploadedFiles.find(f => f.id === fileId);
            if (fileObj) {
                showModal('View File', `File: ${fileObj.file.name}<br>Size: ${formatFileSize(fileObj.file.size)}<br>Type: ${fileObj.file.type || 'Unknown'}`);
            }
        }

        function deleteFile(fileId) {
            uploadedFiles = uploadedFiles.filter(f => f.id !== fileId);
            const fileItem = document.querySelector(`.file-item[data-id="${fileId}"]`);
            if (fileItem) {
                fileItem.remove();
                showNotification('File deleted successfully', 'success');
            }
        }

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        // Main Functions
        function refreshData() {
            const btn = document.getElementById('refresh-data');
            const originalText = btn.innerHTML;

            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';
            btn.disabled = true;

            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;

                // Update last updated time
                const now = new Date();
                const options = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
                document.getElementById('last-updated').textContent = now.toLocaleDateString('en-US', options);

                showNotification('Data refreshed successfully!', 'success');
            }, 1500);
        }

        function applyFilters() {
            const btn = document.getElementById('apply-filters');
            const originalText = btn.innerHTML;

            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Applying...';
            btn.disabled = true;

            // Collect filter values
            const filters = {
                serviceTypes: [],
                channels: [],
                adSpendMax: document.getElementById('ad-spend-range').value,
                conversionMin: document.getElementById('conversion-range').value
            };

            // Get checked service types
            document.querySelectorAll('input[type="checkbox"]:checked').forEach(checkbox => {
                if (['plumbing', 'electrical', 'hvac', 'emergency', 'other'].includes(checkbox.id)) {
                    filters.serviceTypes.push(checkbox.id);
                }
                if (['google-ads', 'facebook', 'direct-mail', 'referral'].includes(checkbox.id)) {
                    filters.channels.push(checkbox.id);
                }
            });

            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;

                showNotification('Filters applied successfully!', 'success');
                console.log('Applied filters:', filters);
            }, 1000);
        }

        function resetFilters() {
            // Reset all checkboxes
            document.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                checkbox.checked = true;
            });

            // Reset sliders
            document.getElementById('ad-spend-range').value = 50000;
            document.getElementById('ad-spend-value').textContent = '$50,000';
            document.getElementById('conversion-range').value = 2.5;
            document.getElementById('conversion-value').textContent = '2.5%';

            // Update filter counts
            updateFilterCounts();

            showNotification('All filters have been reset.', 'info');
        }

        function updateAdSpendValue() {
            const value = parseInt(document.getElementById('ad-spend-range').value);
            document.getElementById('ad-spend-value').textContent = '$' + value.toLocaleString();
        }

        function updateConversionValue() {
            const value = document.getElementById('conversion-range').value;
            document.getElementById('conversion-value').textContent = value + '%';
        }

        function updateFilterCounts() {
            // Update service type count
            const serviceCount = document.querySelectorAll('input[type="checkbox"][id="plumbing"], input[type="checkbox"][id="electrical"], input[type="checkbox"][id="hvac"], input[type="checkbox"][id="emergency"], input[type="checkbox"][id="other"]:checked').length;
            document.querySelectorAll('.filter-group h4')[0].querySelector('.filter-count').textContent = serviceCount + ' selected';

            // Update channel count
            const channelCount = document.querySelectorAll('input[type="checkbox"][id="google-ads"], input[type="checkbox"][id="facebook"], input[type="checkbox"][id="direct-mail"], input[type="checkbox"][id="referral"]:checked').length;
            document.querySelectorAll('.filter-group h4')[1].querySelector('.filter-count').textContent = channelCount + ' selected';
        }

        function switchHeatmapTab(e) {
            const tabs = document.querySelectorAll('.chart-tab');
            tabs.forEach(t => t.classList.remove('active'));

            this.classList.add('active');

            const tabType = this.getAttribute('data-tab');
            document.getElementById('day-heatmap').style.display = tabType === 'day' ? 'flex' : 'none';
            document.getElementById('time-heatmap').style.display = tabType === 'time' ? 'flex' : 'none';
            document.getElementById('hourly-heatmap').style.display = tabType === 'hourly' ? 'flex' : 'none';
        }

        function toggleDownloadMenu(e) {
            if (e) e.stopPropagation();
            const menu = document.getElementById('download-options');
            menu.classList.toggle('show');
        }

        function closeDownloadMenu(e) {
            const downloadBtn = document.getElementById('download-btn');
            const downloadOptions = document.getElementById('download-options');

            if (!downloadBtn.contains(e.target) && !downloadOptions.contains(e.target)) {
                downloadOptions.classList.remove('show');
            }
        }

        function handleDownload(e) {
            const format = this.getAttribute('data-format');
            document.getElementById('download-options').classList.remove('show');

            showNotification(`Exporting data as ${format.toUpperCase()}...`, 'info');

            setTimeout(() => {
                showNotification(`Report exported successfully as ${format.toUpperCase()}!`, 'success');
            }, 1000);
        }

        function showNotifications() {
            showModal('Notifications', `
                <h4>Recent Alerts (3)</h4>
                <div style="margin-top: 15px;">
                    <div style="background: #fff3cd; padding: 10px; border-radius: 8px; margin-bottom: 10px;">
                        <strong><i class="fas fa-exclamation-triangle" style="color: #ffc107;"></i> CPA Increased</strong>
                        <p>Cost per acquisition increased by 10% for Plumbing campaigns</p>
                    </div>
                    <div style="background: #f8d7da; padding: 10px; border-radius: 8px; margin-bottom: 10px;">
                        <strong><i class="fas fa-times-circle" style="color: #dc3545;"></i> Facebook Performance</strong>
                        <p>Facebook ad performance dropped below target threshold</p>
                    </div>
                    <div style="background: #d1ecf1; padding: 10px; border-radius: 8px;">
                        <strong><i class="fas fa-lightbulb" style="color: #17a2b8;"></i> New Opportunity</strong>
                        <p>New high-converting keyword detected: "emergency plumber"</p>
                    </div>
                </div>
            `);

            // Clear notification badge
            document.querySelector('.notification-badge').textContent = '0';
            document.querySelector('.notification-badge').style.display = 'none';
        }

        // Modal Functions
        function showModal(title, content) {
            document.getElementById('modal-title').textContent = title;
            document.getElementById('modal-body').innerHTML = content;
            document.getElementById('details-modal').classList.add('show');
        }

        function closeModal() {
            document.getElementById('details-modal').classList.remove('show');
        }

        function modalAction() {
            showNotification('Action completed successfully!', 'success');
            closeModal();
        }

        // Notification System
        function showNotification(message, type = 'info') {
            // Remove existing notifications
            document.querySelectorAll('.notification').forEach(n => n.remove());

            // Create notification element
            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'}"></i>
                <span>${message}</span>
            `;

            document.body.appendChild(notification);

            // Animate in
            setTimeout(() => {
                notification.classList.add('show');
            }, 10);

            // Remove after 3 seconds
            setTimeout(() => {
                notification.classList.remove('show');
                setTimeout(() => {
                    if (notification.parentNode) {
                        notification.parentNode.removeChild(notification);
                    }
                }, 300);
            }, 3000);
        }

        // Keyboard Shortcuts
        document.addEventListener('keydown', function(e) {
            // Ctrl + R to refresh
            if (e.ctrlKey && e.key === 'r') {
                e.preventDefault();
                refreshData();
            }

            // Ctrl + F to focus filters
            if (e.ctrlKey && e.key === 'f') {
                e.preventDefault();
                document.querySelector('.filters-panel').scrollIntoView({ behavior: 'smooth' });
            }

            // Escape to close modals and menus
            if (e.key === 'Escape') {
                closeModal();
                document.getElementById('download-options').classList.remove('show');
            }
        });

        // Update current time
        function updateTime() {
            const now = new Date();
            const timeString = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

            const timeElements = document.querySelectorAll('.current-time');
            timeElements.forEach(el => {
                el.textContent = timeString;
            });
        }

        // Update time every minute
        setInterval(updateTime, 60000);
        updateTime();
    </script>
