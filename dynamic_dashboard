                    labels: ['Google Ads', 'Facebook/Instagram', 'Direct Mail', 'Referral Programs'],
                    datasets: [
                        {
                            label: 'Sign-ups',
                            data: [620, 340, 180, 107],
                            backgroundColor: '#4caf50',
                            borderColor: '#4caf50',
                            borderWidth: 1
                        },
                        {
                            label: 'Cost per Acquisition',
                            data: [75, 92, 120, 45],
                            backgroundColor: '#2196f3',
                            borderColor: '#2196f3',
                            borderWidth: 1,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
