                                {x: 2400, y: 45}
                            ],
                            backgroundColor: '#ef6c00',
                            pointRadius: 8,
                            pointHoverRadius: 12
                        },
                        {
                            label: 'HVAC',
                            data: [
                                {x: 1200, y: 15},
                                {x: 1600, y: 22},
                                {x: 1900, y: 28},
                                {x: 2300, y: 32},
                                {x: 2600, y: 38}
                            ],
                            backgroundColor: '#2e7d32',
                            pointRadius: 8,
                            pointHoverRadius: 12
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: 'Ad Spend ($)'
                            },
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        y: {
                            title: {
